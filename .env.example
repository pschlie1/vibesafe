# Database (PostgreSQL - required)
DATABASE_URL="postgresql://user:pass@host:5432/scantient?pgbouncer=true"
# DIRECT_URL should be a non-pooled direct connection URL for Prisma migrations
DIRECT_URL="postgresql://user:pass@host:5432/scantient"


# Auth
JWT_SECRET="replace-with-random-secret"
# ENCRYPTION_KEY is used for AES-256-GCM encryption of sensitive config values (e.g. SSO clientSecret).
# Use a strong random string (e.g. openssl rand -base64 32). Keep separate from JWT_SECRET.
ENCRYPTION_KEY=""

# Cron security
CRON_SECRET="replace-me"

# Scantient's own probe token — used to authenticate calls to /api/internal/probe
# Generate with: openssl rand -hex 32
SCANTIENT_PROBE_TOKEN=""

# Stripe billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""

# Email alerts (Resend)
RESEND_API_KEY=""
ALERT_FROM_EMAIL="alerts@scantient.com"

# App URL
NEXT_PUBLIC_URL="https://scantient.vercel.app"

# Observability (Sentry)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="0"
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Distributed rate limiting (recommended for multi-instance production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
RATE_LIMIT_PREFIX="scantient:rate-limit"
# Global fallback mode if Redis is unavailable: fail-open | fail-closed
RATE_LIMIT_FALLBACK_MODE="fail-open"
# Throttle degradation alerts/instrumentation (seconds)
RATE_LIMIT_DEGRADED_ALERT_WINDOW_SECONDS="300"

# Health thresholds
HEALTH_CRON_STALE_MINUTES="360"
