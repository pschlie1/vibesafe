# Database (PostgreSQL - required)
DATABASE_URL="postgresql://user:pass@host:5432/vibesafe?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/vibesafe"

# Auth
JWT_SECRET="replace-with-random-secret"

# Cron security
CRON_SECRET="replace-me"

# Stripe billing
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_STARTER_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""

# Email alerts (Resend)
RESEND_API_KEY=""
ALERT_FROM_EMAIL="alerts@vibesafe.app"

# App URL
NEXT_PUBLIC_URL="https://vibesafe.vercel.app"

# Observability (Sentry)
SENTRY_DSN=""
SENTRY_ENVIRONMENT="production"
SENTRY_TRACES_SAMPLE_RATE="0"
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Distributed rate limiting (recommended for multi-instance production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
RATE_LIMIT_PREFIX="vibesafe:rate-limit"
# Global fallback mode if Redis is unavailable: fail-open | fail-closed
RATE_LIMIT_FALLBACK_MODE="fail-open"

# Health thresholds
HEALTH_CRON_STALE_MINUTES="360"
