{
  "name": "vibesafe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage --passWithNoTests",
    "test:ci": "vitest run --coverage --passWithNoTests --pool=forks",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:backup": "bash ./scripts/db-backup.sh",
    "db:restore:verify": "bash ./scripts/db-restore-verify.sh",
    "export:incident-evidence": "tsx ./scripts/export-incident-evidence.ts",
    "export:change-report": "tsx ./scripts/export-change-report.ts",
    "export:gtm-baseline": "tsx ./scripts/export-gtm-baseline.ts",
    "ci": "npm run lint && npm run typecheck && npm run test:ci && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "@react-email/components": "^1.0.8",
    "@sentry/nextjs": "^10.40.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "prisma": "^6.16.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.35",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
